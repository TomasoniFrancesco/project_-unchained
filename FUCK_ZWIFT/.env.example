# FUCK ZWIFT — Environment Variables
# Copy to .env and fill in your values.
# These override config.toml settings.

# Server
# FUCKZWIFT_PORT=5050
# FUCKZWIFT_HOST=0.0.0.0
# FUCKZWIFT_DEBUG=false

# Strava API (from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Data directory (default: ./data)
# FUCKZWIFT_DATA_DIR=./data
