# UNCHAINED PROJECT — Environment Variables
# Copy to .env and fill in your values.
# These override config.toml settings.

# Server
# UNCHAINED_PROJECT_PORT=5050
# UNCHAINED_PROJECT_HOST=0.0.0.0
# UNCHAINED_PROJECT_DEBUG=false

# Strava API (from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Data directory (default: ./data)
# UNCHAINED_PROJECT_DATA_DIR=./data
